{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "yes:explosion_fire_sparks",
			"basic_render_parameters": {
				"material": "particles_add",
				"texture": "textures/particle/sparks2"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "variable.s = math.pow(v.size_mult*1.5??1,1/2);variable.width = 1.3;variable.height = 0.06;v.a = math.pow(300/5, 1/(v.duration/20??2));v.b = math.ln(300)/math.ln(v.a);"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": "math.pow(v.a,-v.emitter_age+v.b)",
				"max_particles": 400
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": "v.duration/20??2",
				"sleep_time": 5
			},
			"minecraft:emitter_shape_point": {
				"direction": ["math.random(-1,1)", "math.random(-0.3,0.3)", "math.random(-1,1)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "0.8+ Math.Random(0, 0.6)"
			},
			"minecraft:particle_initial_speed": "math.random(10*v.s,30*v.s)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "-3.5*v.s", 0],
				"linear_drag_coefficient": 1.5
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["(variable.width*(v.particle_random_1*(1-0.5)+0.5)*(v.particle_lifetime-v.particle_age))*v.s", "(variable.height*(v.particle_random_1*(1-0.5)+0.5)*(v.particle_lifetime-v.particle_age))*v.s"],
				"facing_camera_mode": "lookat_direction",
				"uv": {
					"texture_width": 32,
					"texture_height": 32,
					"uv": [0, 0],
					"uv_size": [32, 32]
				}
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 1,
				"collision_radius": 0.01
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.08": "#D6FF920B",
						"0.33": "#F2FCDB39",
						"0.66": "#85F6EDC5",
						"1.0": "#00FFFFFF"
					}
				}
			}
		}
	}
}