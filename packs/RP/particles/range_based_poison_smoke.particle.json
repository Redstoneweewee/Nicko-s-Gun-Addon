{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "yes:range_based_poison_smoke",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/smoke"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "variable.dur = v.duration??200;variable.r = v.range+2??10;v.d = v.drag??2;v.a = 2;v.size = v.r/v.a;v.speed = (30*v.d*v.r*(2*v.a-1))/(2*v.a*(30-v.d));"
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {
				"direction": ["math.random(-1,1)", "math.random(-0.3,0.5)", "math.random(-1,1)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "v.dur/20"
			},
			"minecraft:particle_initial_speed": "math.random(v.speed/2,v.speed)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, "-v.speed/15*(1-v.emitter_age/(v.dur/20))", 0],
				"linear_drag_coefficient": "v.d"
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["v.size", "v.size"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 32,
					"texture_height": 32,
					"uv": [0, 0],
					"uv_size": [32, 32]
				}
			},
			"minecraft:particle_motion_collision": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#63206210",
						"0.82": "#2B44C638",
						"1.0": "#00779C69"
					}
				}
			}
		}
	}
}