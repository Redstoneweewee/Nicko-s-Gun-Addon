{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "yes:custom_fog",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/default"
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.in = v.fade_in_duration;v.out = v.fade_out_duration;v.stay = v.stay_duration;v.opacity = 0;v.particle_duration = 0;",
				"per_update_expression": "v.particle_duration = v.emitter_age*20;v.opacity = (v.particle_duration > v.in && v.particle_duration <= (v.in + v.stay)) ? 1 : (v.particle_duration <= v.in ? (1-(v.in-v.particle_duration)/v.in) : ((v.in + v.stay + v.out) - v.particle_duration)/v.out);"
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 25
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 100,
				"direction": "outwards"
			},
			"minecraft:emitter_shape_point": {},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "(v.fade_in_duration + v.stay_duration + v.fade_out_duration)/20"
			},
			"minecraft:particle_initial_speed": 1.5,
			"minecraft:particle_appearance_billboard": {
				"size": [1000, 1000],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 16,
					"uv": [0, 0],
					"uv_size": [16, 16]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": ["v.color.r", "v.color.g", "v.color.b", "v.opacity"]
			}
		}
	}
}